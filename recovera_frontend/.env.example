# FastAPI chatbot backend already used by your current app.
# Use CHAT_API_URL when you want to paste the full endpoint, for example https://recovera-api.your-domain.com/api/chat
# Use CHAT_API_BASE_URL when you want the app to append /api/chat automatically.
CHAT_API_URL=
CHAT_API_BASE_URL=
COPILOT_API_URL=

# Shared secret matching API_SECRET_KEY on the HuggingFace backend.
# Every request to /api/chat is forwarded with  X-API-Key: <this value>.
# Keep this server-side only — do NOT prefix with NEXT_PUBLIC_.
BACKEND_API_KEY=

# Supabase direct Postgres connection string. Keep this SERVER-SIDE only.
# Use Supabase Transaction Pooler for Vercel serverless if possible.
# Example: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# If local Node shows "self-signed certificate in certificate chain", keep sslmode=require and leave PG_SSL_REJECT_UNAUTHORIZED unset.
# Set PG_SSL_REJECT_UNAUTHORIZED=true only if your environment has the correct trusted CA chain.
PG_SSL_REJECT_UNAUTHORIZED=false
SUPABASE_DB_URL=

# Optional aliases supported by the app:
# SUPABASE_POOLER_URL=
# POSTGRES_URL=
# DATABASE_URL=
# DATABASE_POOL_URL=
# DATABASE_POOL=
