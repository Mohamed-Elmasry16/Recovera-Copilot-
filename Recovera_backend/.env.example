# API keys
JINA_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=

# Models
JINA_MODEL=jina-embeddings-v5
JINA_EMBED_DIM=1024
GROQ_MODEL=llama-3.3-70b-versatile
MODEL_SQL=z-ai/glm-4.5-air:free
MODEL_VALIDATOR=deepseek/deepseek-v4-flash:free
MODEL_ANALYTICS=minimax/minimax-m2.5:free
VALIDATOR_LLM_ENABLED=false

# DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revenue_leakage
DB_USER=chatbot_readonly
DB_PASSWORD=
DB_POOL_MIN=2
DB_POOL_MAX=10

# Runtime
STATEMENT_TIMEOUT_MS=15000
MAX_QUERY_ROWS=200
QUERY_CACHE_TTL_SECONDS=86400
SCHEMA_CACHE_TTL_SECONDS=3600
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
